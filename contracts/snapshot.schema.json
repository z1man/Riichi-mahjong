{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "snapshot.schema.json",
  "title": "Snapshot",
  "type": "object",
  "required": ["gameId", "seq", "phase", "scores", "turnSeat", "waitingFor", "legalActions"],
  "properties": {
    "gameId": { "type": "string" },
    "seq": { "type": "integer" },
    "phase": { "type": "string" },
    "scores": { "type": "array", "items": { "type": "integer" }, "minItems": 4, "maxItems": 4 },
    "turnSeat": { "type": "integer", "minimum": 0, "maximum": 3 },
    "waitingFor": { "type": "string" },
    "legalActions": { "type": "array" }
  },
  "additionalProperties": true
}
